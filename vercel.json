{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/ops/digest", "schedule": "0 17 * * *" },
    { "path": "/ops/monthly-report", "schedule": "0 18 1 * *" }
  ]
}
