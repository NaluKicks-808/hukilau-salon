# --- Salon Scheduler (AppHeaven/Clover) merchant ---
MERCHANT_ID=SVEVNSQKF87J1

# --- Server ---
PORT=8787
# Shared secret Vapi must send in the `x-vapi-secret` header to authorize tool calls.
VAPI_SECRET=change-me-to-a-long-random-string

# --- Optional ---
# Force the salon timezone used for all date math. Defaults to jsonMerchant.timezone
# (Pacific/Honolulu for this merchant). Pacific/Honolulu is UTC-10 with no DST.
SALON_TZ=Pacific/Honolulu
# Set to 1 to print the lifted availability engine's verbose debug logging.
AVAIL_DEBUG=0
# How long (ms) to cache the salon's booked-appointments pull. Default 45000 (45s).
APPT_CACHE_TTL_MS=45000

# --- Pending-hold overlay (Upstash Redis) ---
# Credentials are AUTO-DETECTED from the Vercel/Upstash Marketplace integration env vars
# (any prefix, e.g. KV_REST_API_URL / UPSTASH_REDIS_REST_URL). No manual setup needed if you
# added Upstash via the Vercel Marketplace. Optional: override how long a hold lasts before the
# salon's own calendar takes over (default 129600 = 36 hours).
HOLD_TTL_SECONDS=129600

# --- Owner notifications: Notion database (recommended — auto-enables when both are set) ---
# Each captured booking/cancel/reschedule becomes a row in your "Booking Requests" database.
#  1) Create an internal integration at https://www.notion.so/my-integrations -> copy its secret.
#  2) Open the Booking Requests database -> "..." -> Connections -> add that integration.
#  3) Set both of these in Vercel (Project -> Settings -> Environment Variables):
NOTION_API_KEY=                                    # the integration's Internal Integration Secret (ntn_...)
NOTION_DATABASE_ID=58a66f27f10a408b9cc173e062501e44
# NOTION_VERSION=2022-06-28                         # override only if Notion changes the default API version

# --- Permanent call archive: "📞 Call Log" Notion database ---
# Every Vapi end-of-call report becomes one page (outcome properties + full transcript in the
# body) — Vapi purges call data after days; this copy is forever and feeds the monthly client
# report. The database must be shared with the SAME integration as Booking Requests
# (open the DB -> ... -> Connections -> add it). Uses NOTION_API_KEY above.
NOTION_CALLS_DB_ID=15f5d73811354d499f14878ca398ad97
# Optional label for the Client select column (multi-client future): defaults to Hukilau Salon.
# CLIENT_NAME=

# --- Owner push notifications via Pushover (the salon owner's phone) ---
PUSHOVER_TOKEN=
PUSHOVER_USER=

# --- Operator alerts + ops page (Nalu Agency / Evan — NOT the salon owner) ---
# Pushover user or group key that receives technical alerts (tool errors, flagged calls, failed
# owner delivery) and the 7:00 AM HST daily digest (vercel.json cron, 17:00 UTC). Safe to leave
# unset: alerts fall back to log-only breadcrumbs.
PUSHOVER_DEV_USER=
# Optional separate Pushover app token for ops alerts; defaults to PUSHOVER_TOKEN.
PUSHOVER_DEV_TOKEN=
# Optional passphrase protecting GET /ops and /ops/digest (append ?key=...). RECOMMENDED — call
# summaries are visible on the page. If you set OPS_KEY, ALSO set CRON_SECRET, otherwise the
# scheduled daily digest starts 401ing (Vercel sends CRON_SECRET as `Authorization: Bearer ...`
# on cron requests automatically once the env var exists).
OPS_KEY=
# Shared secret for cron-triggered endpoints (/warm via x-cron-secret, /ops/digest via Bearer).
CRON_SECRET=

# --- Owner SMS notifications via Telnyx ---
# When these are set (in Vercel), the booking/cancel/reschedule tools text the owner on each
# captured request. The assistant still returns the request to Vapi as well. Auto-enables when
# present — no NOTIFY_MODE needed.
TELNYX_API_KEY=
TELNYX_FROM=+18086630659          # your Telnyx number (E.164); must be on a Telnyx Messaging Profile
OWNER_PHONE=+18087510081          # where owner alerts are sent
# Alternative to TELNYX_FROM: TELNYX_MESSAGING_PROFILE_ID=
# Legacy option: NOTIFY_MODE=twilio with TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN / TWILIO_FROM
